{
  "mcpServers": {
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "@iflow-mcp/fetch@1.0.2"
      ],
      "values": {}
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@iflow-mcp/server-github@0.6.2"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "values": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": {
          "type": "string",
          "title": "GitHub个人访问令牌",
          "description": "GitHub个人访问令牌。在GitHub设置中生成个人访问令牌",
          "default": "your_github_token_here"
        }
      }
    },
    "mcp-server-code-runner": {
      "description": "多语言代码执行器，支持35种编程语言的代码片段执行，包括JavaScript、Python、Go、Java等主流语言",
      "command": "npx",
      "args": [
        "-y",
        "@iflow-mcp/mcp-server-code-runner"
      ]
    },
    "fastmcp-data-analysis-server": {
      "description": "提供全面的数据分析工具，包括统计函数、概率分布计算和数据处理功能",
      "command": "uvx",
      "args": [
        "--from",
        "iflow-mcp_fastmcp-data-analysis-server",
        "fastmcp-data-analysis-server"
      ]
    },
    "text-toolkit": {
      "description": "提供全面的文本处理功能，包括大小写转换、编码解码、格式化、统计分析等工具",
      "command": "npx",
      "args": [
        "-y",
        "@iflow-mcp/text-toolkit"
      ]
    },
    "desktop-commander": {
      "description": "强大的桌面文件系统和进程管理工具，提供文件操作、搜索、进程管理等全面功能",
      "command": "npx",
      "args": [
        "-y",
        "@iflow-mcp/desktop-commander"
      ]
    },
    "mcp-memory-system": {
      "description": "提供基于代理的工作区隔离和文件系统管理功能，支持多代理环境下的安全文件操作",
      "command": "uvx",
      "args": [
        "--python",
        "3.12.7",
        "iflow-mcp_memory-system@latest",
        "--workspace-path",
        "."
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@iflow-mcp/server-sequential-thinking@0.6.2"
      ],
      "values": {}
    }
  },
  "disableAutoUpdate": true
}